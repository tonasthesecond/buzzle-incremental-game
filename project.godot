;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Buzzle"
run/main_scene="uid://bj341en8f28fl"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="uid://c4virkxoyn6xe"

[autoload]

GameStore="*uid://ce5tcfplcvouy"
SignalBus="*uid://cdsqosi2l6cvd"

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/window_width_override=1280
window/size/window_height_override=960
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Bee Idle"

[editor]

naming/scene_name_casing=1
naming/script_name_casing=1

[global_group]

bees=""

[input]

save_game={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":true,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":83,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

